# Copy this file to .env.development and .env.production
# Never commit actual .env files to version control

# App
APP_ENV=development
APP_NAME=Prabhupad Ashraya

# Firebase — values come from google-services.json / GoogleService-Info.plist
# These are only needed if you use the JS SDK directly.
# With @react-native-firebase, config is read from native files automatically.
FIREBASE_PROJECT_ID=prabhupad-ashraya-dev

# Feature Flags
FEATURE_EXPORT_ENABLED=false
FEATURE_DARK_MODE_ENABLED=false
